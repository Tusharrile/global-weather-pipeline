{
  "datasets": [
    {
      "name": "c075bfae",
      "displayName": "Top 10 Hottest Countries",
      "queryLines": [
        "SELECT country, avg_temp_celsius, max_temp_celsius, min_temp_celsius\n",
        "FROM global_weather_catalog.gold.insight_top_temperatures\n",
        "ORDER BY avg_temp_celsius DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "7e48409b",
      "displayName": "Air Quality by Country",
      "queryLines": [
        "SELECT country, avg_pm2_5, avg_pm10, avg_co, avg_epa_index\n",
        "FROM global_weather_catalog.gold.insight_air_quality\n",
        "ORDER BY avg_pm2_5 DESC\n",
        "LIMIT 15"
      ]
    },
    {
      "name": "38d5b3f7",
      "displayName": "Top 10 Rainfall Countries",
      "queryLines": [
        "SELECT country, total_rainfall_mm, avg_rainfall_mm, max_rainfall_mm\n",
        "FROM global_weather_catalog.gold.insight_rainfall\n",
        "ORDER BY total_rainfall_mm DESC LIMIT 10"
      ]
    },
    {
      "name": "39fd052c",
      "displayName": "Wind Speed by Country",
      "queryLines": [
        "SELECT country, avg_wind_kph, max_wind_kph\n",
        "FROM global_weather_catalog.gold.insight_wind\n",
        "ORDER BY avg_wind_kph DESC LIMIT 15"
      ]
    },
    {
      "name": "f8e2c8e2",
      "displayName": "UV Risk Distribution",
      "queryLines": [
        "SELECT uv_risk_level, COUNT(*) as record_count\n",
        "FROM global_weather_catalog.gold.insight_uv_risk\n",
        "GROUP BY uv_risk_level"
      ]
    },
    {
      "name": "98b16c8e",
      "displayName": "Weather Conditions",
      "queryLines": [
        "SELECT condition_text, total_readings, percentage, avg_temp, avg_humidity\n",
        "FROM global_weather_catalog.gold.insight_conditions\n",
        "ORDER BY total_readings DESC"
      ]
    },
    {
      "name": "e55c57ec",
      "displayName": "Humidity by Country",
      "queryLines": [
        "SELECT country, avg_humidity, humidity_level\n",
        "FROM global_weather_catalog.gold.insight_humidity\n",
        "ORDER BY avg_humidity DESC LIMIT 8"
      ]
    },
    {
      "name": "5f955d3c",
      "displayName": "Extreme Weather Events",
      "queryLines": [
        "SELECT country, extreme_events, extreme_pct, max_wind_kph\n",
        "FROM global_weather_catalog.gold.insight_extreme_weather\n",
        "ORDER BY extreme_events DESC LIMIT 15"
      ]
    },
    {
      "name": "d4249f47",
      "displayName": "Visibility by Country",
      "queryLines": [
        "SELECT condition_text, visibility_category, avg_visibility_km, avg_cloud_cover, reading_count\n",
        "FROM global_weather_catalog.gold.insight_visibility\n",
        "ORDER BY avg_visibility_km DESC LIMIT 15"
      ]
    },
    {
      "name": "6a541da6",
      "displayName": "Cloud vs Air Quality",
      "queryLines": [
        "SELECT cloud_category, avg_pm2_5, avg_pm10, avg_ozone\n",
        "FROM global_weather_catalog.gold.insight_cloud_air_quality\n",
        "ORDER BY avg_pm2_5 DESC"
      ]
    },
    {
      "name": "5eb9563d",
      "displayName": "Day vs Night Temp",
      "queryLines": [
        "SELECT country, is_day, avg_temp, max_temp, min_temp\n",
        "FROM global_weather_catalog.gold.insight_day_night_temp\n",
        "ORDER BY country, is_day LIMIT 30"
      ]
    },
    {
      "name": "90f60ded",
      "displayName": "Pressure by Country",
      "queryLines": [
        "SELECT country, avg_pressure_mb, max_pressure_mb, min_pressure_mb\n",
        "FROM global_weather_catalog.gold.insight_pressure\n",
        "ORDER BY avg_pressure_mb DESC LIMIT 15"
      ]
    },
    {
      "name": "068cc69c",
      "displayName": "Best Weather Destinations",
      "queryLines": [
        "SELECT country, weather_score, avg_temp, avg_uv, avg_wind\n",
        "FROM global_weather_catalog.gold.insight_best_weather\n",
        "ORDER BY weather_score DESC LIMIT 20"
      ]
    },
    {
      "name": "275bda53",
      "displayName": "Summary Stats",
      "queryLines": [
        "SELECT \n",
        "  (SELECT COUNT(DISTINCT country) FROM global_weather_catalog.gold.insight_top_temperatures) as total_countries,\n",
        "  (SELECT ROUND(AVG(avg_temp_celsius), 1) FROM global_weather_catalog.gold.insight_top_temperatures) as global_avg_temp,\n",
        "  (SELECT MAX(avg_wind_kph) FROM global_weather_catalog.gold.insight_wind) as max_wind_recorded,\n",
        "  (SELECT ROUND(AVG(avg_pm2_5), 1) FROM global_weather_catalog.gold.insight_air_quality) as global_avg_pm25"
      ]
    }
  ],
